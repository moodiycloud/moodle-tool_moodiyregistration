{{!
    @template tool_moodiyregistraion/warningbox

    Template for the warning box to display message with continue button.

    Example context (json):
    {
        "confirmtitle": "Title",
        "message": "Display message",
        "continue": "http://example.com/admin/tool/moodiyregistraion/index.php"
    }

}}

<div class="generalbox modal modal-dialog modal-in-page show" role="alertdialog" aria-labelledby="modal-header" aria-describedby="modal-body" aria-modal="true">
    <div class="modal-content">
        <div class="modal-header px-3">
            <h4 id="modal-header">{{confirmtitle}}</h4>
        </div>
        <div class="modal-body" id="modal-body" role="alert" data-aria-autofocus="true">
            <p>{{{message}}}</p>
        </div>
        <div class="modal-footer">
            <div class="buttons">{{{continue}}}</div>
        </div>
    </div>
</div>
